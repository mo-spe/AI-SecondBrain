# ============================================================
# AI-SecondBrain 环境配置文件示例
# ============================================================
# 说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. 不要将 .env 文件提交到代码仓库
# ============================================================

# ============ 数据库配置 ============
# MySQL root密码（请修改为强密码）
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password_here

# MySQL数据库名称
MYSQL_DATABASE=second_brain

# MySQL用户名
MYSQL_USER=secondbrain

# MySQL用户密码（请修改为强密码）
MYSQL_PASSWORD=your_secure_mysql_password_here

# MySQL端口（宿主机端口）
MYSQL_PORT=3306

# ============ Redis配置 ============
# Redis密码（请修改为强密码）
REDIS_PASSWORD=your_secure_redis_password_here

# Redis端口（宿主机端口）
REDIS_PORT=6379

# ============ Elasticsearch配置 ============
# Elasticsearch端口（宿主机端口）
ES_PORT=9200

# Elasticsearch JVM内存设置
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ============ Kafka配置 ============
# Kafka端口（宿主机端口）
KAFKA_PORT=9092

# Zookeeper端口（宿主机端口）
ZOOKEEPER_PORT=2181

# ============ 后端配置 ============
# 后端服务端口（宿主机端口）
BACKEND_PORT=8080

# JVM内存设置
JAVA_OPTS=-Xms512m -Xmx1024m

# ============ 前端配置 ============
# 前端服务端口（宿主机端口）
FRONTEND_PORT=80

# ============ Nginx配置 ============
# 你的域名（例如：example.com）
# 如果没有域名，使用localhost或服务器IP
DOMAIN_NAME=localhost

# 是否启用HTTPS（true/false）
ENABLE_HTTPS=false

# ============ AI服务配置 ============
# AI提供商（qwen/deepseek/openai）
AI_PROVIDER=qwen

# 通义千问API密钥（必填）
QWEN_API_KEY=your_qwen_api_key_here

# 通义千问API地址
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 通义千问模型
QWEN_MODEL=qwen-plus

# 通义千问Embedding API地址
QWEN_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# 通义千问Embedding模型
QWEN_EMBEDDING_MODEL=text-embedding-v2

# DeepSeek API密钥（可选）
DEEPSEEK_API_KEY=

# DeepSeek API地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek模型
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API密钥（可选）
OPENAI_API_KEY=

# OpenAI API地址
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI模型
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI Embedding API地址
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings

# OpenAI Embedding模型
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ============ DeerFlow配置 ============
# DeerFlow API地址
DEERFLOW_API_URL=http://deerflow:8000

# DeerFlow API超时时间（秒）
DEERFLOW_API_TIMEOUT=300

# ============ 阿里云OSS配置（可选） ============
# OSS访问域名
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# OSS AccessKey ID
ALIYUN_OSS_ACCESS_KEY_ID=

# OSS AccessKey Secret
ALIYUN_OSS_ACCESS_KEY_SECRET=

# OSS Bucket名称
ALIYUN_OSS_BUCKET_NAME=thesecondbrain

# ============ 邮件服务配置（可选） ============
# 是否启用邮件服务（true/false）
MAIL_ENABLED=false

# SMTP服务器地址
MAIL_HOST=smtp.qq.com

# SMTP端口
MAIL_PORT=587

# SMTP用户名（邮箱地址）
MAIL_USERNAME=

# SMTP密码（邮箱授权码）
MAIL_PASSWORD=

# ============ 其他配置 ============
# 时区
TZ=Asia/Shanghai

# ============ 重要提示 ============
# 1. 请务必修改所有默认密码
# 2. 不要将 .env 文件提交到代码仓库
# 3. 定期更新API密钥和密码
# 4. 生产环境建议使用强密码
